<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Course Video</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Bootstrap CSS -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >
</head>
<body>

<%
  // safety: userData undefined असेल तर null
  const userDataSafe = typeof userData !== "undefined" ? userData : null;
%>

<!-- ✅ HEADER -->
<%- include("./components/studentheader.ejs", { userData: userDataSafe }) %>

<div class="container mt-4">

  <h3><%= course.title %> - Course Video</h3>

  <video width="100%" height="500" controls autoplay  id="courseVideo">
    <source src="http://localhost:1000/videos/<%= videoUrl %>" type="video/mp4" >

  </video>
  <!-- VIDEO -->
<!-- QUIZ BUTTON -->
<div class="mt-3 text-center">
  <button
    id="quizBtn"
    class="btn btn-success"
    disabled
  >
    Take Quiz
  </button>
</div>

<p id="statusMsg" class="text-center text-primary mt-2"></p>


<!-- ✅ SCRIPT -->
<script>
  document.addEventListener("DOMContentLoaded", function () {

    const video = document.getElementById("courseVideo");  
    const quizBtn = document.getElementById("quizBtn");
    const statusMsg = document.getElementById("statusMsg");

    if (!video || !quizBtn) {
      console.error("Video or Quiz button not found");
      return;
    }

    // When video ends
    video.addEventListener("ended", function () {

      // Save progress (optional)
      fetch("/student/course/<%= course._id %>/video-complete", {
        method: "POST",
        headers: {
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          courseId: "<%= course._id %>",
          progress: 100
        })
      }).catch(err => console.error(err));

      // Enable quiz button
      quizBtn.disabled = false;
      statusMsg.innerText = "Video completed! You can take the quiz now.";

    });

    // When quiz button clicked
    quizBtn.addEventListener("click", function () {
      window.location.href = "/studentQuiz/<%= course._id %>";
    });

  });
</script>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
