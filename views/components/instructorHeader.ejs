<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Instructor Panel</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- FontAwesome -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<!-- Navbar -->
<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
  <div class="container-fluid">
    <!-- Logo / Brand -->
    <a class="navbar-brand fw-bold" href="/instructorDashboard">🎓 Instructor Panel</a>

    <!-- Mobile Toggle Button -->
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Navbar Links -->
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <% if (role === 'instructor') { %>
          <li class="nav-item">
            <a class="nav-link" href="/instructorDashboard"><i class="fa fa-home me-1"></i> Dashboard</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/instructorCreate"><i class="fa fa-book me-1"></i> Create Course</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/instructorEarnings"><i class="fa fa-wallet me-1"></i> Earnings</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/instructorAnalysis"><i class="fa fa-chart-line me-1"></i> Analysis</a>
          </li>
        <% } %>
      </ul>

      <!-- Right Side Profile / Auth Buttons -->
     <ul class="navbar-nav ms-auto align-items-center">
  <li class="nav-item dropdown">

    <a class="nav-link dropdown-toggle d-flex align-items-center gap-2"
       href="#"
       id="instructorDropdown"
       role="button"
       data-bs-toggle="dropdown"
       aria-expanded="false">
      <img src="/<%= userData.profile || 'default.png' %>"alt="profile" width="40" height="40"class="rounded-circle">

      <span class="badge bg-success px-3 py-2">
        <%= userData.name %>
      </span>
    </a>

    <ul class="dropdown-menu dropdown-menu-end"
        aria-labelledby="instructorDropdown">

      <li>
        <a class="dropdown-item" href="/profile">
          Edit Profile
        </a>
      </li>

      <li><hr class="dropdown-divider"></li>

      <li>
        <a class="dropdown-item text-danger"
           href="/logout">
           Logout
        </a>
      </li>

    </ul>
  </li>
</ul>

    </div>
  </div>
</nav>

<!-- Bootstrap JS -->
</body>
<script src="/js/bootstrap.bundle.min.js"></script>

<!-- <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script> -->
</html>
