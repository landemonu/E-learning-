<!DOCTYPE html>
<html>
<head>
  <title>Instructor Earnings</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>
<%- include("./components/instructorHeader.ejs") %>

<div class="container mt-4">
  <h3>Total Earnings: ₹ <%= totalEarnings %></h3>

  <table class="table table-bordered mt-3">
    <thead class="table-dark">
      <tr>
        <th>#</th>
        <th>Course</th>
        <th>Amount</th>
        <th>Date</th>
      </tr>
    </thead>
    <tbody>
      <% earnings.forEach((e, index) => { %>
        <tr>
          <td><%= index + 1 %></td>
          <td><%= e.course.title %></td>
          <td>₹ <%= e.amount %></td>
          <td><%= e.createdAt.toDateString() %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

</body>
</html>
