<% if (typeof activeQuiz === "undefined") activeQuiz = null; %>
<% if (typeof quizzes === "undefined") quizzes = []; %>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Student Quiz</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    .quiz-box {
      background: #fff;
      padding: 25px;
      border-radius: 12px;
      box-shadow: 0 0 12px rgba(0,0,0,0.1);
    }

    .option-item {
      padding: 6px 0;
    }
  </style>
</head>

<body class="bg-light">

<!-- Header -->
<%- include("components/studentheader.ejs") %>

<div class="container mt-4 mb-5">

  <h3 class="mb-4">Course Quiz</h3>


  <!-- ================= LOCK MESSAGE ================= -->

  <% if ((!quizzes || quizzes.length === 0) && !activeQuiz) { %>

    <div class="alert alert-info text-center">
      🔒 Complete all videos to unlock the quiz.
    </div>

  <% } %>


  <!-- ================= QUIZ LIST ================= -->

  <% if (quizzes && quizzes.length > 0 && !activeQuiz) { %>

    <% quizzes.forEach(qz => { %>

      <div class="card mb-3 shadow-sm">

        <div class="card-body d-flex justify-content-between align-items-center">

          <div>
            <h5 class="mb-1"><%= qz.title %></h5>
            <small class="text-muted">Available Quiz</small>
          </div>

          <form action="/studentQuiz/start" method="POST">
            <input type="hidden" name="quizId" value="<%= qz._id %>">

            <button type="submit" class="btn btn-success">
              ▶ Start Quiz
            </button>
          </form>

        </div>

      </div>

    <% }) %>

  <% } %>


  <!-- ================= ACTIVE QUIZ ================= -->

  <% if (activeQuiz) { %>

    <div class="quiz-box">

      <h4 class="mb-4 text-center">
        <%= activeQuiz.title %>
      </h4>


    <form action="/studentQuiz/submit" method="POST">

  <input type="hidden" name="quizId" value="<%= activeQuiz._id %>">

  <% activeQuiz.questions.forEach((q, i) => { %>

    <h5><%= q.text %></h5>

    <% q.options.forEach((opt, j) => { %>

      <label>
        <input type="radio"
               name="answers[<%= i %>]"
               value="<%= j %>"
               required>
        <%= opt %>
      </label><br>

    <% }) %>

  <% }) %>

  <button type="submit">Submit</button>

</form>

    </div>

  <% } %>


  <!-- ================= FAILED MESSAGE ================= -->

  <!-- <% if (typeof failed !== "undefined" && failed) { %>

    <div class="alert alert-danger text-center mt-4">

      ❌ You failed the quiz. Please try again.

      <br><br>

      <strong>
        Score: <%= score %> / <%= total %>
      </strong>

    </div>

  <% } %> -->
  <% if (typeof failed !== "undefined" && failed) { %>

  <div class="alert alert-danger text-center mt-4">

    ❌ You failed the quiz. Please try again.

    <br><br>

    <strong>
      Score: <%= score %> / <%= total %>
    </strong>

    <br><br>

    <form action="/studentQuiz/start" method="POST">

      <input type="hidden" name="quizId" value="<%= quizId %>">

      <button class="btn btn-warning">
        🔄 Retake Quiz
      </button>

    <a href="/studentCertificate" class="btn btn-warning">Generate Certificate</a>
    </form>

  </div>

<% } %>


</div>


<!-- Footer -->


<%- include("./components/footer.ejs") %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

