<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Quiz</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<!-- ❌ semicolon काढला -->

<%- include("./components/instructorHeader.ejs") %>

<div class="container mt-4">
    <h2>Add Quiz for <%= course.title %></h2>

```
<!-- form ला action / method लागत नाही कारण fetch वापरतोय -->
<form id="quizForm">
    <div class="mb-3">
        <label>Quiz Title</label>
        <input id="quizTitle" name="title" class="form-control" required>
    </div>

    <div id="questions"></div>

    <button type="button" id="addQ" class="btn btn-outline-secondary mt-2">
        Add Question
    </button>

    <button type="button" id="saveQuiz" class="btn btn-primary mt-2">
        Save Quiz
    </button>
</form>
```

</div>

<script>
const questionsDiv = document.getElementById('questions');

document.getElementById('addQ').addEventListener('click', () => {
    const idx = questionsDiv.children.length;
    const html = `
    <div class="card mb-2 p-2">
        <label>Question ${idx + 1}</label>
        <input class="form-control q-text mb-1" placeholder="Question text" required>
        <input class="form-control q-opt mb-1" placeholder="Option1, Option2, Option3" required>
        <input class="form-control q-correct" placeholder="Correct option index (0-based)" required>
    </div>`;
    questionsDiv.insertAdjacentHTML('beforeend', html);
});

document.getElementById('saveQuiz').addEventListener('click', async () => {
    const title = document.getElementById('quizTitle').value;

    const cards = Array.from(document.querySelectorAll('.card'));
    const questions = cards.map(card => ({
        text: card.querySelector('.q-text').value,
        options: card.querySelector('.q-opt').value.split(',').map(o => o.trim()),
        correctIndex: parseInt(card.querySelector('.q-correct').value)
    }));

    // ✅ POST URL CORRECT
    const res = await fetch("/instructorAddquiz/<%= course._id %>/quiz/add", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ title, questions })
    });

    if (res.ok) {
        window.location.href = "/instructorDashboard";
    } else {
        alert("Error saving quiz");
    }
});
</script>

<%- include("./components/footer.ejs") %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
